			]
		},
		{
			"name": "Hotel Management",
			"item": [
				{
					"name": "View Hotels Publicly",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/hotels",
							"host": ["{{baseUrl}}"],
							"path": ["hotels"]
						}
					}
				},
